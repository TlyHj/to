#!/usr/bin/env bash
# 输出：仅打印选中的目录路径到标准输出；由外层 shell 函数执行 cd
set -euo pipefail

CACHE_FILE="${HOME}/.to_recent_dirs"
MAX_CACHE="${TO_MAX_CACHE:-20}"

matches=()

die() { printf '%s\n' "$*" >&2; exit 1; }

usage() {
  cat <<'EOF'
用法:
  to <关键字>         按缓存/搜索结果选择目录
  to <已存在目录>     直接输出该目录绝对路径
  to -l               列出缓存
  to -c               清空缓存
  to -r <PATH>        从缓存中移除指定路径
  to -h, --help       显示帮助
EOF
}

abs_path() {
  local target="$1"
  if command -v realpath >/dev/null 2>&1; then
    realpath "$target"
  elif command -v python3 >/dev/null 2>&1; then
    python3 - "$target" <<'PY'
import os, sys
print(os.path.abspath(sys.argv[1]))
PY
  else
    (cd "$target" 2>/dev/null && pwd -P) || return 1
  fi
}

ensure_cache_file() {
  mkdir -p "$(dirname "$CACHE_FILE")"
  touch "$CACHE_FILE"
}

update_cache() {
  local dir="$1" tmp
  ensure_cache_file
  tmp="$(mktemp "${CACHE_FILE}.XXXX")"
  if [[ -f "$CACHE_FILE" ]]; then
    grep -F -x -v -- "$dir" "$CACHE_FILE" > "$tmp" || true
  else
    : > "$tmp"
  fi
  printf '%s\n' "$dir" >> "$tmp"
  tail -n "$MAX_CACHE" "$tmp" > "$CACHE_FILE"
  mv "$CACHE_FILE" "${CACHE_FILE}.bak" 2>/dev/null || true
  mv "$tmp" "$CACHE_FILE"
  rm -f "${CACHE_FILE}.bak"
}

list_cache() {
  if [[ ! -f "$CACHE_FILE" || ! -s "$CACHE_FILE" ]]; then
    echo "缓存为空"
    return 0
  fi
  nl -ba "$CACHE_FILE"
}

clear_cache() {
  ensure_cache_file
  : > "$CACHE_FILE"
  echo "已清空缓存：$CACHE_FILE"
}

remove_cache_entry() {
  local path="$1" abs tmp
  ensure_cache_file
  abs="$(abs_path "$path")" || die "路径不存在：$path"
  tmp="$(mktemp "${CACHE_FILE}.XXXX")"
  grep -F -x -v -- "$abs" "$CACHE_FILE" > "$tmp" || true
  mv "$tmp" "$CACHE_FILE"
  echo "已从缓存移除：$abs"
}

search_recent() {
  local q="$1"
  [[ -f "$CACHE_FILE" ]] || return 0
  grep -i -F -- "$q" "$CACHE_FILE" || true
}

search_plocate() {
  local q="$1"
  if command -v plocate >/dev/null 2>&1; then
    plocate -i -b -0 -- "$q" | \
    while IFS= read -r -d '' p; do
      [[ -d "$p" ]] && printf '%s\n' "$p"
    done
  elif command -v fd >/dev/null 2>&1; then
    fd -t d -i -u -a "$q" / 2>/dev/null || true
  elif command -v fdfind >/dev/null 2>&1; then
    fdfind -t d -i -u -a "$q" / 2>/dev/null || true
  else
    find / -type d -iname "*$q*" 2>/dev/null || true
  fi
}

collect_matches() {
  local q="$1"
  declare -A seen=()
  matches=()
  while IFS= read -r line; do
    [[ -n "$line" ]] || continue
    if [[ -z "${seen[$line]+x}" ]]; then
      seen["$line"]=1
      matches+=("$line")
    fi
  done < <({ search_recent "$q"; search_plocate "$q"; })
}

pick_match() {
  local dir=""
  if [[ ${#matches[@]} -eq 0 ]]; then
    return 1
  fi
  if [[ ${#matches[@]} -eq 1 ]]; then
    dir="${matches[0]}"
  else
    if command -v fzf >/dev/null 2>&1; then
      dir="$(printf '%s\n' "${matches[@]}" | fzf --prompt="选择目录> " --height=40% --reverse --ansi)" || return 1
    else
      echo "找到多个匹配目录，请选择：" >&2
      local i sel
      for ((i=0; i<${#matches[@]}; i++)); do
        printf '%2d) %s\n' "$((i+1))" "${matches[$i]}" >&2
      done
      while :; do
        read -r -p "请输入编号 (或 0 取消): " sel
        [[ "$sel" =~ ^[0-9]+$ ]] || { echo "请输入数字" >&2; continue; }
        if (( sel == 0 )); then return 1; fi
        if (( sel >= 1 && sel <= ${#matches[@]} )); then
          dir="${matches[$((sel-1))]}"
          break
        else
          echo "编号无效，请重试" >&2
        fi
      done
    fi
  fi
  printf '%s\n' "$dir"
}

main() {
  [[ $# -ge 1 ]] || { usage; exit 1; }

  case "${1:-}" in
    -h|--help)
      usage
      exit 0
      ;;
    -l|--list)
      list_cache
      exit 0
      ;;
    -c|--clear)
      clear_cache
      exit 0
      ;;
    -r|--remove)
      [[ $# -ge 2 ]] || die "用法: to -r <PATH>"
      remove_cache_entry "$2"
      exit 0
      ;;
  esac

  local q="$1"
  if [[ -d "$q" ]]; then
    local direct
    direct="$(abs_path "$q")" || die "无法解析目录：$q"
    update_cache "$direct"
    printf '%s\n' "$direct"
    exit 0
  fi

  collect_matches "$q"
  if [[ ${#matches[@]} -eq 0 ]]; then
    die "未找到匹配目录：$q"
  fi

  local dir
  dir="$(pick_match)" || exit 1
  update_cache "$dir"
  printf '%s\n' "$dir"
}

main "$@"
