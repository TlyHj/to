#!/usr/bin/env bash
# 输出：仅打印选中的目录路径到标准输出；由外层 shell 函数执行 cd
set -euo pipefail

CACHE_FILE="${HOME}/.to_recent_dirs"
MAX_CACHE="${TO_MAX_CACHE:-20}"
SEARCH_MAX_DEPTH="${TO_SEARCH_MAX_DEPTH:-6}"
SEARCH_ROOTS_RAW="${TO_SEARCH_ROOTS:-$HOME /opt /srv /usr/local /var/www}"
SEARCH_EXCLUDES_RAW="${TO_SEARCH_EXCLUDES:-/proc /sys /dev /run /tmp /mnt /media /var/tmp /snap}"

matches=()

_die() { printf '%s\n' "$*" >&2; exit 1; }

usage() {
  cat <<'EOF'
用法:
  to <关键字>         按缓存/搜索结果选择目录
  to <已存在目录>     直接输出该目录绝对路径
  to -l               列出缓存
  to -c               清空缓存
  to -r <PATH>        从缓存中移除指定路径
  to -h, --help       显示帮助

环境变量:
  TO_MAX_CACHE          最近目录缓存条数，默认 20
  TO_SEARCH_MAX_DEPTH   fd/find 搜索深度，默认 6
  TO_SEARCH_ROOTS       搜索根目录列表，空格分隔
  TO_SEARCH_EXCLUDES    搜索排除目录列表，空格分隔
EOF
}

abs_path() {
  local target="$1"
  if command -v realpath >/dev/null 2>&1; then
    realpath "$target"
  elif command -v python3 >/dev/null 2>&1; then
    python3 - "$target" <<'PY'
import os, sys
print(os.path.abspath(sys.argv[1]))
PY
  else
    (cd "$target" 2>/dev/null && pwd -P) || return 1
  fi
}

ensure_cache_file() {
  mkdir -p "$(dirname "$CACHE_FILE")"
  touch "$CACHE_FILE"
}

update_cache() {
  local dir="$1" tmp
  ensure_cache_file
  tmp="$(mktemp "${CACHE_FILE}.XXXX")"
  if [[ -f "$CACHE_FILE" ]]; then
    grep -F -x -v -- "$dir" "$CACHE_FILE" > "$tmp" || true
  else
    : > "$tmp"
  fi
  printf '%s\n' "$dir" >> "$tmp"
  tail -n "$MAX_CACHE" "$tmp" > "$CACHE_FILE"
  mv "$CACHE_FILE" "${CACHE_FILE}.bak" 2>/dev/null || true
  mv "$tmp" "$CACHE_FILE"
  rm -f "${CACHE_FILE}.bak"
}

list_cache() {
  if [[ ! -f "$CACHE_FILE" || ! -s "$CACHE_FILE" ]]; then
    echo "缓存为空"
    return 0
  fi
  nl -ba "$CACHE_FILE"
}

clear_cache() {
  ensure_cache_file
  : > "$CACHE_FILE"
  echo "已清空缓存：$CACHE_FILE"
}

remove_cache_entry() {
  local path="$1" abs tmp
  ensure_cache_file
  abs="$(abs_path "$path")" || _die "路径不存在：$path"
  tmp="$(mktemp "${CACHE_FILE}.XXXX")"
  grep -F -x -v -- "$abs" "$CACHE_FILE" > "$tmp" || true
  mv "$tmp" "$CACHE_FILE"
  echo "已从缓存移除：$abs"
}

search_recent() {
  local q="$1"
  [[ -f "$CACHE_FILE" ]] || return 0
  tac "$CACHE_FILE" 2>/dev/null | grep -i -F -- "$q" || grep -i -F -- "$q" "$CACHE_FILE" || true
}

get_search_roots() {
  local root
  for root in $SEARCH_ROOTS_RAW; do
    [[ -d "$root" ]] && printf '%s\n' "$root"
  done
}

path_is_within_search_root() {
  local path="$1" root
  for root in $SEARCH_ROOTS_RAW; do
    [[ -d "$root" ]] || continue
    [[ "$path" == "$root" || "$path" == "$root"/* ]] && return 0
  done
  return 1
}

is_excluded_path() {
  local path="$1" ex
  path_is_within_search_root "$path" && return 1
  for ex in $SEARCH_EXCLUDES_RAW; do
    [[ "$path" == "$ex" || "$path" == "$ex"/* ]] && return 0
  done
  return 1
}

search_plocate() {
  local q="$1" p
  command -v plocate >/dev/null 2>&1 || return 0
  plocate -i -b -0 -- "$q" | while IFS= read -r -d '' p; do
    [[ -d "$p" ]] || continue
    is_excluded_path "$p" && continue
    printf '%s\n' "$p"
  done
}

should_apply_exclude() {
  local root="$1" ex="$2"
  [[ -n "$ex" ]] || return 1
  [[ "$root" == "$ex" || "$root" == "$ex"/* ]] && return 1
  return 0
}

search_fd_like() {
  local cmd="$1" q="$2" root
  command -v "$cmd" >/dev/null 2>&1 || return 0
  while IFS= read -r root; do
    "$cmd" -t d -i -a --max-depth "$SEARCH_MAX_DEPTH" "$q" "$root" 2>/dev/null || true
  done < <(get_search_roots)
}

search_find() {
  local q="$1" root ex_args=() ex
  while IFS= read -r root; do
    ex_args=()
    for ex in $SEARCH_EXCLUDES_RAW; do
      if should_apply_exclude "$root" "$ex"; then
        ex_args+=( -not -path "$ex" -not -path "$ex/*" )
      fi
    done
    find "$root" -maxdepth "$SEARCH_MAX_DEPTH" -type d -iname "*$q*" "${ex_args[@]}" 2>/dev/null || true
  done < <(get_search_roots)
}

search_system() {
  local q="$1"
  if command -v plocate >/dev/null 2>&1; then
    search_plocate "$q"
  fi

  if command -v fd >/dev/null 2>&1; then
    search_fd_like fd "$q"
  elif command -v fdfind >/dev/null 2>&1; then
    search_fd_like fdfind "$q"
  else
    search_find "$q"
  fi
}

score_match() {
  local q_lower="$1" path="$2"
  python3 - "$q_lower" "$path" <<'PY'
import os, sys
q = sys.argv[1].lower()
path = sys.argv[2]
base = os.path.basename(path).lower()
path_lower = path.lower()
score = 0

if base == q:
    score += 1000
elif base.startswith(q):
    score += 700
elif q in base:
    score += 500
elif q in path_lower:
    score += 250

home = os.path.expanduser('~')
if path == home or path.startswith(home + os.sep):
    score += 180
if '/src/' in path_lower or '/code/' in path_lower or '/projects/' in path_lower:
    score += 80

parts = [p for p in path.split(os.sep) if p]
score -= min(len(parts), 20) * 8
score -= min(len(path), 240)
print(score)
PY
}

sort_matches() {
  local q="$1" q_lower
  q_lower="$(printf '%s' "$q" | tr '[:upper:]' '[:lower:]')"
  local path score
  while IFS= read -r path; do
    [[ -n "$path" ]] || continue
    score="$(score_match "$q_lower" "$path")"
    printf '%s\t%s\n' "$score" "$path"
  done | sort -t $'\t' -k1,1nr -k2,2 | cut -f2-
}

collect_matches() {
  local q="$1"
  declare -A seen=()
  matches=()
  while IFS= read -r line; do
    [[ -n "$line" ]] || continue
    [[ -d "$line" ]] || continue
    is_excluded_path "$line" && continue
    if [[ -z "${seen[$line]+x}" ]]; then
      seen["$line"]=1
      matches+=("$line")
    fi
  done < <({ search_recent "$q"; search_system "$q"; } | sort_matches "$q")
}

pick_match() {
  local dir=""
  if [[ ${#matches[@]} -eq 0 ]]; then
    return 1
  fi
  if [[ ${#matches[@]} -eq 1 ]]; then
    dir="${matches[0]}"
  else
    if command -v fzf >/dev/null 2>&1; then
      dir="$(printf '%s\n' "${matches[@]}" | fzf --prompt="选择目录> " --height=40% --reverse --ansi)" || return 1
    else
      echo "找到多个匹配目录，请选择：" >&2
      local i sel
      for ((i=0; i<${#matches[@]}; i++)); do
        printf '%2d) %s\n' "$((i+1))" "${matches[$i]}" >&2
      done
      while :; do
        read -r -p "请输入编号 (或 0 取消): " sel
        [[ "$sel" =~ ^[0-9]+$ ]] || { echo "请输入数字" >&2; continue; }
        if (( sel == 0 )); then return 1; fi
        if (( sel >= 1 && sel <= ${#matches[@]} )); then
          dir="${matches[$((sel-1))]}"
          break
        else
          echo "编号无效，请重试" >&2
        fi
      done
    fi
  fi
  printf '%s\n' "$dir"
}

main() {
  [[ $# -ge 1 ]] || { usage; exit 1; }

  case "${1:-}" in
    -h|--help)
      usage
      exit 0
      ;;
    -l|--list)
      list_cache
      exit 0
      ;;
    -c|--clear)
      clear_cache
      exit 0
      ;;
    -r|--remove)
      [[ $# -ge 2 ]] || _die "用法: to -r <PATH>"
      remove_cache_entry "$2"
      exit 0
      ;;
  esac

  local q="$1"
  if [[ -d "$q" ]]; then
    local direct
    direct="$(abs_path "$q")" || _die "无法解析目录：$q"
    update_cache "$direct"
    printf '%s\n' "$direct"
    exit 0
  fi

  collect_matches "$q"
  if [[ ${#matches[@]} -eq 0 ]]; then
    _die "未找到匹配目录：$q"
  fi

  local dir
  dir="$(pick_match)" || exit 1
  update_cache "$dir"
  printf '%s\n' "$dir"
}

main "$@"
